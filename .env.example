# ===============================================
# CONFIGURACIÓN DEL SISTEMA - TU COBRADOR
# ===============================================
# Copia este archivo como ".env" y completa los valores reales.
# NUNCA subas el archivo ".env" al repositorio.
# ===============================================

# 🌐 MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/TuCobradorDB?retryWrites=true&w=majority

# 🤖 Telegram Bot (obtener desde @BotFather en Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 🔑 Anthropic Claude API (obtener desde https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 🔐 JWT Secret (cualquier string largo y aleatorio)
JWT_SECRET=tu_clave_secreta_random_muy_segura

# 🚀 Puerto y Ambiente
PORT=3000
NODE_ENV=development

# 🌍 URL del Frontend
FRONTEND_URL=http://localhost:3001

# ===============================================
# CÓMO OBTENER LAS CLAVES:
# ===============================================

# MONGO_URI:
# 1. Entra a https://www.mongodb.com/cloud/atlas
# 2. Crea un cluster gratuito
# 3. Ve a Database > Connect > Driver > Node.js
# 4. Copia la URI y reemplaza "contraseña" con tu clave real

# TELEGRAM_TOKEN:
# 1. Abre Telegram y busca @BotFather
# 2. Envía el comando /newbot
# 3. Sigue las instrucciones y copia el token

# ANTHROPIC_API_KEY:
# 1. Entra a https://console.anthropic.com
# 2. Ve a API Keys > Create Key
# 3. Copia y pega aquí
# ===============================================
